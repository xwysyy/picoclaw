    },
    "mistral": {
      "api_key": "",
      "api_base": "https://api.mistral.ai/v1"
    }
  },
  "tools": {
    "web": {
      "brave": {
        "enabled": false,
        "api_key": "YOUR_BRAVE_API_KEY",
        "max_results": 5
      },
      "duckduckgo": {
        "enabled": true,
        "max_results": 5
      },
      "grok": {
        "enabled": false,
        "api_key": "xai-xxx",
        "endpoint": "https://api.x.ai/v1/chat/completions",
        "default_model": "grok-4",
        "max_results": 5
      },
      "evidence_mode": {
        "enabled": false,
        "min_domains": 2
      },
      "proxy": "",
      "fetch_limit_bytes": 10485760
    },
    "mcp": {
      "enabled": false,
      "servers": [
        {
          "name": "example",
          "transport": "stdio",
          "command": "node",
          "args": [
            "/path/to/mcp-server.js"
          ],
          "env": {},
          "include_tools": [],
          "tool_prefix": "mcp_example_",
          "timeout_seconds": 30
        }
      ]
    },
    "policy": {
      "enabled": false,
      "timeout_ms": 0,
      "allow": [],
      "allow_prefixes": [],
      "deny": [],
      "deny_prefixes": [],
      "redact": {
        "enabled": true,
        "apply_to_llm": false,
        "apply_to_user": false,
        "json_fields": [
          "api_key",
          "apikey",
          "token",
          "access_token",
          "refresh_token",
          "secret",
          "password",
          "authorization",
          "cookie"
        ],
        "patterns": [
          "(?i)(authorization\\s*:\\s*)(bearer\\s+)[^\\s]+",
          "(?i)(api[_-]?key\\s*[:=]\\s*)[^\\s]+",
          "(?i)(access[_-]?token\\s*[:=]\\s*)[^\\s]+",
          "(?i)(refresh[_-]?token\\s*[:=]\\s*)[^\\s]+",
          "\\bsk-[A-Za-z0-9]{16,}\\b"
        ]
      },
      "confirm": {
        "enabled": false,
        "mode": "resume_only",
        "expires_seconds": 900,
        "tools": [
          "exec",
          "write_file",
          "edit_file",
          "append_file"
        ],
        "tool_prefixes": [
          "mcp_"
        ]
      },
      "idempotency": {
        "enabled": true,
        "cache_result": true,
        "tools": [
          "exec",
          "write_file",
          "edit_file",
          "append_file"
        ],
        "tool_prefixes": [
          "mcp_"
        ]
      },
      "audit": {
        "tags": {}
      }
    },
    "plan_mode": {
      "enabled": true,
      "default_mode": "run",
      "restricted_tools": [
        "exec",
        "write_file",
        "edit_file",
        "append_file"
      ],
      "restricted_prefixes": []
    },
    "estop": {
      "enabled": true,
      "fail_closed": true
    },
    "error_template": {
      "enabled": false,
      "include_schema": true
    },
    "trace": {
      "enabled": false,
      "dir": "",
      "write_per_call_files": true,
      "max_arg_preview_chars": 200,
      "max_result_preview_chars": 400
    },
    "cron": {
      "exec_timeout_minutes": 5
    },
    "exec": {
      "enable_deny_patterns": false,
      "custom_deny_patterns": [],
      "custom_allow_patterns": [],
      "_comment": "backend: host | docker. Docker backend runs commands in a disposable container with workspace mounted at /workspace.",
      "backend": "host",
      "docker": {
        "image": "alpine:3.20",
        "network": "none",
        "read_only_rootfs": true
      }
    },
    "git": {
      "enabled": false,
      "username": "your-github-username",
      "pat": "github_pat_xxx",
      "user_name": "Your Name",
      "user_email": "you@example.com",
      "host": "github.com",
      "protocol": "https"
    },
    "skills": {
      "registries": {
        "clawhub": {
          "enabled": true,
          "base_url": "https://clawhub.ai",
          "search_path": "/api/v1/search",
          "skills_path": "/api/v1/skills",
          "download_path": "/api/v1/download"
        }
      }
    },
    "media_cleanup": {
      "enabled": true,
      "max_age_minutes": 30,
      "interval_minutes": 5
    }
  },
  "heartbeat": {
    "enabled": true,
    "interval": 5
  },
  "orchestration": {
    "enabled": false,
    "max_spawn_depth": 3,
    "max_parallel_workers": 8,
    "max_tasks_per_agent": 20,
    "default_task_timeout_seconds": 180,
    "retry_limit_per_task": 2,
    "tool_calls_parallel_enabled": true,
    "max_tool_call_concurrency": 8,
    "parallel_tools_mode": "read_only_only",
    "tool_parallel_overrides": {}
  },
  "audit": {
    "enabled": false,
    "interval_minutes": 30,
    "lookback_minutes": 180,
    "min_confidence": 0.75,
    "inconsistency_policy": "strict",
    "auto_remediation": "safe_only",
    "max_auto_remediations_per_cycle": 3,
    "remediation_cooldown_minutes": 10,
    "remediation_agent_id": "",
    "notify_channel": "last_active",
    "supervisor": {
      "enabled": false,
      "model": {
        "primary": "gpt-5.2",
        "fallbacks": [
          "claude-sonnet-4.6"
        ]
      },
      "temperature": 0.0,
      "max_tokens": 2048
    }
  },
  "notify": {
    "on_task_complete": false
  },
  "gateway": {
    "_comment": "gateway.api_key secures /api/notify, /api/estop and /api/console/* (loopback-only when empty; bearer token when set). /console/ UI stays browser-friendly and uses the key to call /api/console/*.",
    "host": "127.0.0.1",
    "port": 18790,
    "api_key": "",
    "inbound_queue": {
      "enabled": true,
      "max_concurrency": 4,
      "per_session_buffer": 32
    }
  }
}
